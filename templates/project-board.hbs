<section class="project-board-body" data-drop-zone>

  {{!-- Empty state --}}
  {{#if isEmpty}}
  <div class="board-empty">
    <i class="fas fa-users fa-3x"></i>
    <p>No heroes registered.</p>
    {{#if @root.isGM}}
    <p class="hint">Drag a PC actor from the sidebar onto this window to get started.</p>
    {{else}}
    <p class="hint">Click the button below to add your character to the board.</p>
    {{/if}}
  </div>
  {{/if}}

  {{!-- Player "Add my character" buttons --}}
  {{#if ownedHeroes.length}}
  <div class="add-own-hero-bar">
    {{#each ownedHeroes as |oh|}}
    <button type="button" class="btn btn-add-own-hero" data-action="addOwnHero" data-actor-id="{{oh.actorId}}">
      <img src="{{oh.img}}" alt="{{oh.name}}" width="24" height="24" />
      <span>Add {{oh.name}}</span>
    </button>
    {{/each}}
  </div>
  {{/if}}

  {{#unless isEmpty}}
  <div class="project-board-toolbar">
    {{!-- Hero tabs --}}
    {{#if heroTabs.length}}
    <div class="hero-tabs" role="tablist" aria-label="Party Members">
      {{#each heroTabs as |heroTab|}}
      <button
        type="button"
        class="hero-tab {{#if heroTab.isActive}}active{{/if}}"
        data-action="selectHeroTab"
        data-actor-id="{{heroTab.actorId}}"
        role="tab"
        aria-selected="{{#if heroTab.isActive}}true{{else}}false{{/if}}"
      >
        <img src="{{heroTab.img}}" alt="{{heroTab.name}}" width="24" height="24" />
        <span>{{heroTab.name}}</span>
      </button>
      {{/each}}
    </div>
    {{/if}}
  </div>

  <div class="project-board-scroll">
  {{!-- Active hero card --}}
  {{#if activeHero}}
  <div class="hero-card" data-actor-id="{{activeHero.actorId}}">

    {{!-- Hero header --}}
    <div class="hero-header">
      <img class="hero-portrait" src="{{activeHero.img}}" alt="{{activeHero.name}}" width="48" height="48" />
      <div class="hero-info">
        <h3 class="hero-name">{{activeHero.name}}</h3>
        {{#if activeHero.career}}
        <div class="career-line">
          <span class="career-name">{{activeHero.career.name}}</span>
          <span class="career-points" title="Career project points currently available on the hero sheet: {{activeHero.career.available}}{{#if activeHero.career.trackedSpent}}. Tracker ledger career entries: {{activeHero.career.trackedSpent}}{{/if}}">
            <i class="fas fa-coins"></i>
            <strong>{{activeHero.career.available}}</strong> PP available
            {{#if activeHero.career.trackedSpent}}<span class="allocated">({{activeHero.career.trackedSpent}} tracked spent)</span>{{/if}}
          </span>
        </div>
        {{/if}}
      </div>
      {{#if activeHero.canEdit}}
      <button type="button" class="icon-btn remove-hero" data-action="removeHero" data-tooltip="Remove Hero">
        <i class="fas fa-times"></i>
      </button>
      {{/if}}
    </div>

    {{!-- Projects --}}
    {{#if activeHero.projects.length}}
    <div class="project-list">
      {{#each activeHero.projects as |proj|}}
      <div class="project-card {{#if proj.completed}}completed{{/if}}" data-item-id="{{proj.itemId}}">

        <div class="project-header">
          <span class="project-name">{{proj.name}}</span>
          <span class="project-type badge badge-{{proj.type}}">{{proj.typeLabel}}</span>
          {{#if activeHero.canEdit}}
          <button type="button" class="icon-btn remove-project" data-action="removeProject" data-tooltip="Remove Project">
            <i class="fas fa-trash"></i>
          </button>
          {{/if}}
        </div>

        {{!-- Progress bar --}}
        <div class="progress-row">
          <div class="progress-bar-container">
            <div class="progress-bar-fill {{#if proj.completed}}complete{{/if}}" style="width: {{proj.pct}}%;"></div>
          </div>
          <span class="progress-label">{{proj.points}} / {{proj.goal}} <small>({{proj.pct}}%)</small></span>
        </div>

        {{!-- Detail rows --}}
        {{#if proj.projectSource}}
        <div class="detail-row">
          <i class="fas fa-book"></i>
          <span class="detail-label">Source:</span>
          <span class="detail-value">{{proj.projectSource}}</span>
        </div>
        {{/if}}
        {{#if proj.prerequisites}}
        <div class="detail-row">
          <i class="fas fa-list-check"></i>
          <span class="detail-label">Prerequisites:</span>
          <span class="detail-value">{{proj.prerequisites}}</span>
        </div>
        {{/if}}

        {{!-- Action buttons --}}
        <div class="project-actions">
          {{#unless proj.completed}}
          {{#if activeHero.canEdit}}
          {{#if proj.canSpendCareerPoints}}
          <button type="button" class="btn btn-sm btn-career" data-action="spendCareerPoints" data-tooltip="Spend Career Points">
            <i class="fas fa-hammer"></i> Spend PP
          </button>
          {{/if}}
          <button type="button" class="btn btn-sm" data-action="addPoints" data-tooltip="Add Points">
            <i class="fas fa-plus"></i> Add Points
          </button>
          <button type="button" class="btn btn-sm" data-action="rollProgress" data-tooltip="Roll for Progress">
            <i class="fas fa-dice-d20"></i> Roll
          </button>
          {{#if proj.canDrawEvent}}
          <button type="button" class="btn btn-sm btn-event" data-action="drawProjectEvent" data-tooltip="Draw Project Event">
            <i class="fas fa-sparkles"></i> Event
          </button>
          {{/if}}
          {{#if proj.canComplete}}
          <button type="button" class="btn btn-sm btn-complete" data-action="completeProject" data-tooltip="Mark Complete">
            <i class="fas fa-check-circle"></i> Complete
          </button>
          {{/if}}
          {{/if}}
          {{/unless}}
          <button type="button" class="btn btn-sm btn-ledger" data-action="viewLedger" data-tooltip="View Point Ledger">
            <i class="fas fa-scroll"></i> Ledger ({{proj.ledgerCount}})
          </button>
        </div>

      </div>
      {{/each}}
    </div>
    {{else}}
    <div class="no-projects">
      <p class="hint"><i class="fas fa-inbox"></i> No projects. Drag a project item onto this hero to add one.</p>
    </div>
    {{/if}}

    {{!-- Add custom project button --}}
    {{#if activeHero.canEdit}}
    <div class="add-project-bar">
      <button type="button" class="btn btn-sm btn-add-project" data-action="addCustomProject" data-tooltip="Create a new custom project">
        <i class="fas fa-plus"></i> New Project
      </button>
    </div>
    {{/if}}

  </div>
  {{/if}}
  </div>
  {{/if}}
  {{/unless}}

</section>
